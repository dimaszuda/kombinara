generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// PHASE 1 — Auth + Role + Kelas + Settings
// ============================================================

model User {
  id        String   @id @map("user_id") @db.Uuid // UUID dari Supabase auth.users.id
  email     String   @unique
  name      String
  role      String
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  taughtClasses   Class[]           @relation("TeacherClasses")
  student         Student?
  readingProgress ReadingProgress[]
  aiQuestions     AiQuestion[]
  quizAttempts    QuizAttempt[]
  ulanganAttempts UlanganAttempt[]
  activityScore   ActivityScore?
  badges          UserBadge[]

  @@map("users")
}

model Class {
  id           Int     @id @default(autoincrement()) @map("class_id")
  teacherId    String? @map("teacher_id") @db.Uuid
  className    String  @map("class_name")
  group        String
  academicYear String  @map("academic_year")

  // Relations
  teacher  User?          @relation("TeacherClasses", fields: [teacherId], references: [id])
  students Student[]
  settings ClassSettings?
  ulangan  Ulangan[]

  @@map("classes")
}

model Student {
  id            Int    @id @default(autoincrement()) @map("student_id")
  userId        String @unique @map("user_id") @db.Uuid
  studentNumber String @unique @map("student_number")
  name          String
  gender        String
  classId       Int    @map("class_id")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  class Class @relation(fields: [classId], references: [id])
  apersepsiResponses      ApersepsiPemantikResponse[]
  drafts                  AsesmenFormatifDraft[]
  submissions             AsesmenFormatifSubmission[]
  eksplorasiKontekstual   EksplorasiKontekstual[]
  aktivitasDeepLearning   AktivitasDeepLearning[]
  refleksiMini            RefleksiMini[]
  aktivitasSiswaEntries   AktivitasSiswaEntry[]
  aiMessages              AiMessage[]

  @@map("students")
}

model ClassSettings {
  id              Int      @id @default(autoincrement())
  classId         Int      @unique @map("class_id")
  readingWeight   Float    @default(0.25) @map("reading_weight")
  frequencyWeight Float    @default(0.25) @map("frequency_weight")
  depthWeight     Float    @default(0.30) @map("depth_weight")
  quizWeight      Float    @default(0.20) @map("quiz_weight")
  leaderboardMode String   @default("activity_score") @map("leaderboard_mode")
  updatedAt       DateTime @updatedAt @map("updated_at")

  class           Class    @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@map("class_settings")
}

// ============================================================
// PHASE 2 — Materi + Reading Tracking + AI Q&A
// ============================================================

model Materi {
  id          Int       @id @default(autoincrement())
  slug        String    @unique
  judul       String
  konten      Json
  urutan      Int
  publishedAt DateTime? @map("published_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  sections        MateriSection[]
  readingProgress ReadingProgress[]
  quizzes         Quiz[]
  aiQuestions     AiQuestion[]

  @@map("materi")
}

model MateriSection {
  id        Int    @id @default(autoincrement())
  materiId  Int    @map("materi_id")
  sectionId String @map("section_id")
  judul     String
  urutan    Int

  materi          Materi            @relation(fields: [materiId], references: [id], onDelete: Cascade)
  readingProgress ReadingProgress[]

  @@unique([materiId, sectionId])
  @@map("materi_sections")
}

model ReadingProgress {
  id                Int      @id @default(autoincrement())
  siswaId           String   @map("siswa_id") @db.Uuid
  materiId          Int      @map("materi_id")
  sectionId         Int      @map("section_id")
  timeOnSectionSecs Int      @default(0) @map("time_on_section_secs")
  updatedAt         DateTime @updatedAt @map("updated_at")

  siswa   User          @relation(fields: [siswaId], references: [id], onDelete: Cascade)
  materi  Materi        @relation(fields: [materiId], references: [id], onDelete: Cascade)
  section MateriSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@unique([siswaId, materiId, sectionId])
  @@map("reading_progress")
}

model AiQuestion {
  id            Int      @id @default(autoincrement())
  siswaId       String   @map("siswa_id") @db.Uuid
  materiId      Int      @map("materi_id")
  selectedText  String   @map("selected_text")
  question      String
  response      String?
  depthScore    Int?     @map("depth_score")
  depthCategory String?  @map("depth_category")
  createdAt     DateTime @default(now()) @map("created_at")

  siswa  User   @relation(fields: [siswaId], references: [id], onDelete: Cascade)
  materi Materi @relation(fields: [materiId], references: [id], onDelete: Cascade)

  @@map("ai_questions")
}

// Panel Chatbot — menyimpan semua percakapan siswa dengan AI
model AiMessage {
  messageId      Int      @id @default(autoincrement()) @map("message_id")
  studentId      Int      @map("student_id")
  conversationId String   @map("conversation_id") @db.Uuid
  role           String   // "user" | "assistant"
  content        String
  createdAt      DateTime @default(now()) @map("created_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([conversationId])
  @@index([studentId, conversationId])
  @@map("ai_messages")
}

// ============================================================
// PHASE 3 — Quiz + Ulangan + Handwritten
// ============================================================

enum TipeSoal {
  mcq
  isian
  handwritten
}

model Quiz {
  id       Int    @id @default(autoincrement())
  materiId Int    @map("materi_id")
  judul    String

  materi   Materi        @relation(fields: [materiId], references: [id], onDelete: Cascade)
  soal     Soal[]
  attempts QuizAttempt[]

  @@map("quizzes")
}

model Soal {
  id           Int       @id @default(autoincrement())
  quizId       Int?      @map("quiz_id")
  ulanganId    Int?      @map("ulangan_id")
  tipe         TipeSoal
  pertanyaan   String
  opsi         Json?
  jawabanBenar String?   @map("jawaban_benar")
  rubrik       String?
  bobot        Int       @default(10)
  urutan       Int

  quiz    Quiz?          @relation(fields: [quizId], references: [id], onDelete: Cascade)
  ulangan Ulangan?       @relation(fields: [ulanganId], references: [id], onDelete: Cascade)
  jawaban JawabanSiswa[]

  @@map("soal")
}

model QuizAttempt {
  id        Int       @id @default(autoincrement())
  quizId    Int       @map("quiz_id")
  siswaId   String    @map("siswa_id") @db.Uuid
  score     Float?
  selesaiAt DateTime? @map("selesai_at")
  createdAt DateTime  @default(now()) @map("created_at")

  quiz    Quiz           @relation(fields: [quizId], references: [id], onDelete: Cascade)
  siswa   User           @relation(fields: [siswaId], references: [id], onDelete: Cascade)
  jawaban JawabanSiswa[]

  @@map("quiz_attempts")
}

model Ulangan {
  id          Int      @id @default(autoincrement())
  classId     Int      @map("class_id")
  judul       String
  durasiMenit Int      @map("durasi_menit")
  mulaiAt     DateTime @map("mulai_at")
  selesaiAt   DateTime @map("selesai_at")
  createdAt   DateTime @default(now()) @map("created_at")

  class    Class            @relation(fields: [classId], references: [id], onDelete: Cascade)
  soal     Soal[]
  attempts UlanganAttempt[]

  @@map("ulangan")
}

model UlanganAttempt {
  id             Int       @id @default(autoincrement())
  ulanganId      Int       @map("ulangan_id")
  siswaId        String    @map("siswa_id") @db.Uuid
  score          Float?
  tabSwitchCount Int       @default(0) @map("tab_switch_count")
  autoSubmitted  Boolean   @default(false) @map("auto_submitted")
  selesaiAt      DateTime? @map("selesai_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  ulangan Ulangan        @relation(fields: [ulanganId], references: [id], onDelete: Cascade)
  siswa   User           @relation(fields: [siswaId], references: [id], onDelete: Cascade)
  jawaban JawabanSiswa[]

  @@unique([ulanganId, siswaId])
  @@map("ulangan_attempts")
}

model JawabanSiswa {
  id               Int      @id @default(autoincrement())
  soalId           Int      @map("soal_id")
  quizAttemptId    Int?     @map("quiz_attempt_id")
  ulanganAttemptId Int?     @map("ulangan_attempt_id")
  jawaban          String?
  imageUrl         String?  @map("image_url")
  isCorrect        Boolean? @map("is_correct")
  score            Float?
  aiFeedback       Json?    @map("ai_feedback")
  submittedAt      DateTime @default(now()) @map("submitted_at")

  soal           Soal            @relation(fields: [soalId], references: [id], onDelete: Cascade)
  quizAttempt    QuizAttempt?    @relation(fields: [quizAttemptId], references: [id], onDelete: Cascade)
  ulanganAttempt UlanganAttempt? @relation(fields: [ulanganAttemptId], references: [id], onDelete: Cascade)

  @@map("jawaban_siswa")
}

// ============================================================
// PHASE 4 — Activity Score + Badge
// ============================================================

model ActivityScore {
  id                Int      @id @default(autoincrement())
  siswaId           String   @unique @map("siswa_id") @db.Uuid
  kelasId           Int      @map("kelas_id")
  readingEngagement Float    @default(0) @map("reading_engagement")
  questionFrequency Float    @default(0) @map("question_frequency")
  questionDepth     Float    @default(0) @map("question_depth")
  quizScore         Float    @default(0) @map("quiz_score")
  totalScore        Float    @default(0) @map("total_score")
  updatedAt         DateTime @updatedAt @map("updated_at")

  siswa User @relation(fields: [siswaId], references: [id], onDelete: Cascade)

  @@map("activity_scores")
}

model Badge {
  id        Int    @id @default(autoincrement())
  nama      String @unique
  deskripsi String
  iconUrl   String @map("icon_url")
  kondisi   Json

  userBadges UserBadge[]

  @@map("badges")
}

model UserBadge {
  userId   String   @map("user_id") @db.Uuid
  badgeId  Int      @map("badge_id")
  earnedAt DateTime @default(now()) @map("earned_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@id([userId, badgeId])
  @@map("user_badges")
}

// ============================================================
// PHASE 5 — Apersepsi + Pemantik + Refleksi Responses
// ============================================================

model ApersepsiPemantikResponse {
  responseId        Int      @id @default(autoincrement()) @map("response_id")
  studentId         Int      @map("student_id")
  section           String
  questionKey       String   @map("question_key")
  responseData      Json     @map("response_data")
  isCorrect         Boolean? @map("is_correct")
  misconceptionType String?  @map("misconception_type")
  feedback          String?  @map("feedback")
  submittedAt       DateTime @default(now()) @map("submitted_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId], name: "idx_apr_student")
  @@index([section], name: "idx_apr_section")
  @@map("apersepsi_pemantik_responses")
}

// ============================================================
// PHASE 6 — Asesmen Formatif (Draft + Submission)
// ============================================================

model Module {
  id   Int    @id @default(autoincrement()) @map("module_id")
  slug String @unique
  nama String

  drafts      AsesmenFormatifDraft[]
  submissions AsesmenFormatifSubmission[]

  @@map("modules")
}

model AsesmenFormatifDraft {
  id              Int      @id @default(autoincrement()) @map("draft_id")
  studentId       Int      @map("student_id")
  moduleId        Int      @map("module_id")
  questionNumber  Int      @map("question_number")
  caraMengerjakan String?  @map("cara_mengerjakan")
  jawabanAkhir    String?  @map("jawaban_akhir")
  lastSavedAt     DateTime @default(now()) @map("last_saved_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  module  Module  @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([studentId, moduleId, questionNumber])
  @@index([studentId, moduleId])
  @@map("asesmen_formatif_drafts")
}

model AsesmenFormatifSubmission {
  id           Int      @id @default(autoincrement()) @map("submission_id")
  studentId    Int      @map("student_id")
  moduleId     Int      @map("module_id")
  conceptId    String?  @map("concept_id")
  answers      Json     @map("answers")
  submittedAt  DateTime @default(now()) @map("submitted_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  module  Module  @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([studentId, moduleId])
  @@index([studentId])
  @@index([moduleId])
  @@map("asesmen_formatif_submissions")
}

// ============================================================
// PHASE 7 — Eksplorasi Kontekstual, Deep Learning, Refleksi Mini
// ============================================================

model EksplorasiKontekstual {
  id          Int      @id @default(autoincrement()) @map("eksplorasi_id")
  studentId   Int      @map("student_id")
  conceptId   String   @map("concept_id")
  questionKey String   @map("question_key")
  answer      Json     @map("answer")
  feedback    String?  @map("feedback")
  isCorrect   Boolean? @map("is_correct")
  createdAt   DateTime @default(now()) @map("created_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([conceptId])
  @@index([studentId, conceptId, questionKey])
  @@map("eksplorasi_kontekstual")
}

model AktivitasDeepLearning {
  id        Int      @id @default(autoincrement()) @map("deep_learning_id")
  studentId Int      @map("student_id")
  conceptId String   @map("concept_id")
  answer    Json     @map("answer")
  feedback  String?  @map("feedback")
  isCorrect Boolean? @map("is_correct")
  createdAt DateTime @default(now()) @map("created_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([conceptId])
  @@map("aktivitas_deep_learning")
}

model RefleksiMini {
  id          Int      @id @default(autoincrement()) @map("refleksi_id")
  studentId   Int      @map("student_id")
  conceptId   String   @map("concept_id")
  questionKey String   @map("question_key")
  answer      String   @map("answer")
  feedback    String?  @map("feedback")
  isCorrect   Boolean? @map("is_correct")
  createdAt   DateTime @default(now()) @map("created_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([conceptId])
  @@index([studentId, conceptId, questionKey])
  @@map("refleksi_mini")
}

// ============================================================
// PHASE 8 — Aktivitas Siswa Entries (Sequential Unlocked)
// ============================================================

model AktivitasSiswaEntry {
  entryId     Int      @id @default(autoincrement()) @map("entry_id")
  studentId   Int      @map("student_id")
  conceptId   String   @map("concept_id")
  activityKey String   @map("activity_key")
  entryType   String   @map("entry_type")
  questionKey String   @map("question_key")
  answer      String   @map("answer")
  isCorrect   Boolean  @map("is_correct")
  feedback    String?  @map("feedback")
  submittedAt DateTime @default(now()) @map("submitted_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, conceptId, activityKey, questionKey, submittedAt])
  @@index([studentId])
  @@index([studentId, conceptId])
  @@index([studentId, conceptId, activityKey])
  @@map("aktivitas_siswa_entries")
}

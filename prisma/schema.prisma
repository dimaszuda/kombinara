generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// PHASE 1 — Auth + Role + Kelas + Settings
// ============================================================

model User {
  id        String   @id @map("user_id") @db.Uuid // UUID dari Supabase auth.users.id
  email     String   @unique
  name      String
  role      String
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  taughtClasses   Class[]           @relation("TeacherClasses")
  student         Student?
  readingProgress ReadingProgress[]
  aiQuestions     AiQuestion[]
  quizAttempts    QuizAttempt[]
  ulanganAttempts UlanganAttempt[]
  activityScore   ActivityScore?
  badges          UserBadge[]

  @@map("users")
}

model Class {
  id           Int     @id @default(autoincrement()) @map("class_id")
  teacherId    String? @map("teacher_id") @db.Uuid
  className    String  @map("class_name")
  group        String
  academicYear String  @map("academic_year")

  // Relations
  teacher  User?          @relation("TeacherClasses", fields: [teacherId], references: [id])
  students Student[]
  settings ClassSettings?
  ulangan  Ulangan[]

  @@map("classes")
}

model Student {
  id            Int    @id @default(autoincrement()) @map("student_id")
  userId        String @unique @map("user_id") @db.Uuid
  studentNumber String @map("student_number")
  name          String
  gender        String
  classId       Int    @map("class_id")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  class Class @relation(fields: [classId], references: [id])

  @@map("students")
}

model ClassSettings {
  id              Int      @id @default(autoincrement())
  classId         Int      @unique @map("class_id")
  readingWeight   Float    @default(0.25) @map("reading_weight")
  frequencyWeight Float    @default(0.25) @map("frequency_weight")
  depthWeight     Float    @default(0.30) @map("depth_weight")
  quizWeight      Float    @default(0.20) @map("quiz_weight")
  leaderboardMode String   @default("activity_score") @map("leaderboard_mode")
  updatedAt       DateTime @updatedAt @map("updated_at")

  class           Class    @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@map("class_settings")
}

// ============================================================
// PHASE 2 — Materi + Reading Tracking + AI Q&A
// ============================================================

model Materi {
  id          Int       @id @default(autoincrement())
  slug        String    @unique
  judul       String
  konten      Json
  urutan      Int
  publishedAt DateTime? @map("published_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  sections        MateriSection[]
  readingProgress ReadingProgress[]
  quizzes         Quiz[]
  aiQuestions     AiQuestion[]

  @@map("materi")
}

model MateriSection {
  id        Int    @id @default(autoincrement())
  materiId  Int    @map("materi_id")
  sectionId String @map("section_id")
  judul     String
  urutan    Int

  materi          Materi            @relation(fields: [materiId], references: [id], onDelete: Cascade)
  readingProgress ReadingProgress[]

  @@unique([materiId, sectionId])
  @@map("materi_sections")
}

model ReadingProgress {
  id                Int      @id @default(autoincrement())
  siswaId           String   @map("siswa_id") @db.Uuid
  materiId          Int      @map("materi_id")
  sectionId         Int      @map("section_id")
  timeOnSectionSecs Int      @default(0) @map("time_on_section_secs")
  updatedAt         DateTime @updatedAt @map("updated_at")

  siswa   User          @relation(fields: [siswaId], references: [id], onDelete: Cascade)
  materi  Materi        @relation(fields: [materiId], references: [id], onDelete: Cascade)
  section MateriSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@unique([siswaId, materiId, sectionId])
  @@map("reading_progress")
}

model AiQuestion {
  id            Int      @id @default(autoincrement())
  siswaId       String   @map("siswa_id") @db.Uuid
  materiId      Int      @map("materi_id")
  selectedText  String   @map("selected_text")
  question      String
  response      String?
  depthScore    Int?     @map("depth_score")
  depthCategory String?  @map("depth_category")
  createdAt     DateTime @default(now()) @map("created_at")

  siswa  User   @relation(fields: [siswaId], references: [id], onDelete: Cascade)
  materi Materi @relation(fields: [materiId], references: [id], onDelete: Cascade)

  @@map("ai_questions")
}

// ============================================================
// PHASE 3 — Quiz + Ulangan + Handwritten
// ============================================================

enum TipeSoal {
  mcq
  isian
  handwritten
}

model Quiz {
  id       Int    @id @default(autoincrement())
  materiId Int    @map("materi_id")
  judul    String

  materi   Materi        @relation(fields: [materiId], references: [id], onDelete: Cascade)
  soal     Soal[]
  attempts QuizAttempt[]

  @@map("quizzes")
}

model Soal {
  id           Int       @id @default(autoincrement())
  quizId       Int?      @map("quiz_id")
  ulanganId    Int?      @map("ulangan_id")
  tipe         TipeSoal
  pertanyaan   String
  opsi         Json?
  jawabanBenar String?   @map("jawaban_benar")
  rubrik       String?
  bobot        Int       @default(10)
  urutan       Int

  quiz    Quiz?          @relation(fields: [quizId], references: [id], onDelete: Cascade)
  ulangan Ulangan?       @relation(fields: [ulanganId], references: [id], onDelete: Cascade)
  jawaban JawabanSiswa[]

  @@map("soal")
}

model QuizAttempt {
  id        Int       @id @default(autoincrement())
  quizId    Int       @map("quiz_id")
  siswaId   String    @map("siswa_id") @db.Uuid
  score     Float?
  selesaiAt DateTime? @map("selesai_at")
  createdAt DateTime  @default(now()) @map("created_at")

  quiz    Quiz           @relation(fields: [quizId], references: [id], onDelete: Cascade)
  siswa   User           @relation(fields: [siswaId], references: [id], onDelete: Cascade)
  jawaban JawabanSiswa[]

  @@map("quiz_attempts")
}

model Ulangan {
  id          Int      @id @default(autoincrement())
  classId     Int      @map("class_id")
  judul       String
  durasiMenit Int      @map("durasi_menit")
  mulaiAt     DateTime @map("mulai_at")
  selesaiAt   DateTime @map("selesai_at")
  createdAt   DateTime @default(now()) @map("created_at")

  class    Class            @relation(fields: [classId], references: [id], onDelete: Cascade)
  soal     Soal[]
  attempts UlanganAttempt[]

  @@map("ulangan")
}

model UlanganAttempt {
  id             Int       @id @default(autoincrement())
  ulanganId      Int       @map("ulangan_id")
  siswaId        String    @map("siswa_id") @db.Uuid
  score          Float?
  tabSwitchCount Int       @default(0) @map("tab_switch_count")
  autoSubmitted  Boolean   @default(false) @map("auto_submitted")
  selesaiAt      DateTime? @map("selesai_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  ulangan Ulangan        @relation(fields: [ulanganId], references: [id], onDelete: Cascade)
  siswa   User           @relation(fields: [siswaId], references: [id], onDelete: Cascade)
  jawaban JawabanSiswa[]

  @@unique([ulanganId, siswaId])
  @@map("ulangan_attempts")
}

model JawabanSiswa {
  id               Int      @id @default(autoincrement())
  soalId           Int      @map("soal_id")
  quizAttemptId    Int?     @map("quiz_attempt_id")
  ulanganAttemptId Int?     @map("ulangan_attempt_id")
  jawaban          String?
  imageUrl         String?  @map("image_url")
  isCorrect        Boolean? @map("is_correct")
  score            Float?
  aiFeedback       Json?    @map("ai_feedback")
  submittedAt      DateTime @default(now()) @map("submitted_at")

  soal           Soal            @relation(fields: [soalId], references: [id], onDelete: Cascade)
  quizAttempt    QuizAttempt?    @relation(fields: [quizAttemptId], references: [id], onDelete: Cascade)
  ulanganAttempt UlanganAttempt? @relation(fields: [ulanganAttemptId], references: [id], onDelete: Cascade)

  @@map("jawaban_siswa")
}

// ============================================================
// PHASE 4 — Activity Score + Badge
// ============================================================

model ActivityScore {
  id                Int      @id @default(autoincrement())
  siswaId           String   @unique @map("siswa_id") @db.Uuid
  kelasId           Int      @map("kelas_id")
  readingEngagement Float    @default(0) @map("reading_engagement")
  questionFrequency Float    @default(0) @map("question_frequency")
  questionDepth     Float    @default(0) @map("question_depth")
  quizScore         Float    @default(0) @map("quiz_score")
  totalScore        Float    @default(0) @map("total_score")
  updatedAt         DateTime @updatedAt @map("updated_at")

  siswa User @relation(fields: [siswaId], references: [id], onDelete: Cascade)

  @@map("activity_scores")
}

model Badge {
  id        Int    @id @default(autoincrement())
  nama      String @unique
  deskripsi String
  iconUrl   String @map("icon_url")
  kondisi   Json

  userBadges UserBadge[]

  @@map("badges")
}

model UserBadge {
  userId   String   @map("user_id") @db.Uuid
  badgeId  Int      @map("badge_id")
  earnedAt DateTime @default(now()) @map("earned_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@id([userId, badgeId])
  @@map("user_badges")
}

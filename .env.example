# Kombinara — Environment Variables
# Copy ke .env.local dan isi nilainya

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Database (Supabase Postgres)
DATABASE_URL=
DIRECT_URL=

# Upstash Redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Upstash Vector (untuk semantic cache AI chat)
UPSTASH_VECTOR_REST_URL=
UPSTASH_VECTOR_REST_TOKEN=

# OpenAI (untuk chat + semantic embedding)
OPENAI_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# Logging & Alerts (opsional — isi salah satu atau keduanya untuk real-time alert)
# Discord: buat webhook di Server Settings > Integrations > Webhooks
DISCORD_WEBHOOK_URL=
# Slack: buat Incoming Webhook di https://api.slack.com/apps
SLACK_WEBHOOK_URL=
